# Copy to .env and adjust.

# Backend (stateless: no DB)
BACKEND_PORT=8000
LIBREOFFICE_BIN=libreoffice
CORS_ORIGINS=http://localhost:4200,http://localhost:8080

# WMS upstream endpoints (override here if they drift; defaults baked in code)
# WMS_VINCOLI_URL=
# WMS_ISPRA_URL=
# WMS_PCN_URL=

# Frontend
FRONTEND_PORT=4200
API_BASE_URL=http://localhost:8000

# GitHub OAuth App for the PWA's PKCE flow.
# Register at https://github.com/settings/developers (Authorization callback URL: http://localhost:4200/auth/callback)
# These are PUBLIC values — the client_id is safe to ship in the PWA bundle.
GITHUB_CLIENT_ID=
