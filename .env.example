# Copy to .env and adjust.

# Backend (stateless: no DB)
BACKEND_PORT=8000
CORS_ORIGINS=http://localhost:4200,http://localhost:8080,https://archaeo.pro,https://archeo.pro

# Gotenberg PDF service. Local dev points at the docker-compose sidecar.
# In prod, set this to the public Gotenberg URL (https://pdf.archaeo.pro/...)
# in Vercel env vars.
GOTENBERG_URL=http://gotenberg:3000
GOTENBERG_USER=
GOTENBERG_PASSWORD=

# WMS upstream endpoints (override here if they drift; defaults baked in code)
# WMS_VINCOLI_URL=
# WMS_ISPRA_URL=
# WMS_PCN_URL=

# Frontend
FRONTEND_PORT=4200
API_BASE_URL=http://localhost:8000

# GitHub OAuth App for the PWA's PKCE flow.
# Register at https://github.com/settings/developers
#   Authorization callback URL: http://localhost:4200/auth/callback (dev)
#                               https://archaeo.pro/auth/callback (prod)
#
# CLIENT_ID is public (safe to ship in the PWA bundle).
# CLIENT_SECRET is server-side only (Vercel env var in prod). GitHub OAuth
# Apps require it even with PKCE — only GitHub Apps support PKCE-without-secret.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
